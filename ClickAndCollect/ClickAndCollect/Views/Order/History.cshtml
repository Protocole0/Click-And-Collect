@model List<ClickAndCollect.Models.Order>
@using ClickAndCollect.Models
@using System.Globalization
@{
    ViewData["Title"] = "Mes commandes";
}

<div class="container py-5">

    <h2 class="fw-bold mb-4">Mes commandes</h2>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <p class="text-muted mt-3 fs-5">Vous n'avez pas encore passé de commande.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-success mt-2 px-4">
                <i class="bi bi-grid me-2"></i>Parcourir les produits
            </a>
        </div>
    }
    else
    {
        <!-- Divs cachés contenant les détails de chaque commande -->
        @foreach (var order in Model)
        {
            <div id="order-details-@order.Id" class="d-none">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-shop text-success mt-1"></i>
                            <div>
                                <div class="fw-semibold small">@order.Store!.Name</div>
                                <div class="text-muted small">@order.Store.FullAddress</div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-calendar3 text-success mt-1"></i>
                            <div>
                                <div class="fw-semibold small text-capitalize">
                                    @order.Slot!.DateSlot.ToString("dddd d MMMM yyyy", new CultureInfo("fr-FR"))
                                </div>
                                <div class="text-muted small">
                                    @order.Slot.StartTime.ToString(@"hh\:mm") → @order.Slot.EndTime.ToString(@"hh\:mm")
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-2" />

                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Produit</th>
                                <th class="text-center">Qté</th>
                                <th class="text-end">Prix unitaire</th>
                                <th class="text-end">Sous-total</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var line in order.Lines)
                            {
                                <tr>
                                    <td>@line.Product.Name</td>
                                    <td class="text-center">@line.Quantity</td>
                                    <td class="text-end">@line.Product.Price.ToString("0.00") €</td>
                                    <td class="text-end">@line.GetSubTotal().ToString("0.00") €</td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr class="fw-semibold">
                                <td colspan="3" class="text-end">Total</td>
                                <td class="text-end">@order.TotalAmount().ToString("0.00") €</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            </div>
        }

        <!-- Modale -->
        <div class="modal fade" id="orderModal" tabindex="-1" aria-labelledby="orderModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="orderModalLabel">Détail de la commande</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fermer"></button>
                    </div>
                    <div class="modal-body" id="orderModalBody">
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Fermer</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Liste des commandes -->
        <div class="d-flex flex-column gap-3">
            @foreach (var order in Model)
            {
                var (badgeClass, badgeLabel) = order.Status switch
                {
                    OrderStatus.PENDING_PREPARATION => ("bg-warning text-dark", "En préparation"),
                    OrderStatus.READY_FOR_PICKUP    => ("bg-success",            "Prêt à retirer"),
                    OrderStatus.COLLECTED           => ("bg-secondary",           "Récupéré"),
                    _                               => ("bg-light text-dark",     "Brouillon")
                };
                var orderDateStr = order.OrderDate.ToString("dddd d MMMM yyyy", new CultureInfo("fr-FR"));
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4 d-flex justify-content-between align-items-center flex-wrap gap-3">
                        <div>
                            <div class="mb-1">
                                <span class="text-muted small">Commande du</span>
                                <span class="fw-semibold ms-1 text-capitalize">@orderDateStr</span>
                            </div>
                            <div class="text-muted small">
                                <i class="bi bi-shop me-1"></i>@order.Store!.Name
                                &nbsp;·&nbsp;
                                <i class="bi bi-box-seam me-1"></i>@order.Lines.Count produit(s)
                                &nbsp;·&nbsp;
                                <strong>@order.TotalAmount().ToString("0.00") €</strong>
                            </div>
                        </div>
                        <div class="d-flex align-items-center gap-3">
                            <span class="badge @badgeClass rounded-pill px-3 py-2">@badgeLabel</span>
                            <button class="btn btn-outline-success btn-sm"
                                    data-order-id="@order.Id"
                                    data-order-date="@orderDateStr"
                                    onclick="showOrderDetail(this)">
                                <i class="bi bi-eye me-1"></i>Voir le détail
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        function showOrderDetail(btn) {
            const orderId   = btn.dataset.orderId;
            const orderDate = btn.dataset.orderDate;
            const details   = document.getElementById('order-details-' + orderId);

            document.getElementById('orderModalLabel').textContent = 'Commande du ' + orderDate;
            document.getElementById('orderModalBody').innerHTML    = details.innerHTML;

            new bootstrap.Modal(document.getElementById('orderModal')).show();
        }
    </script>
}
