@model ClickAndCollect.Models.Order
@using ClickAndCollect.Models
@{
    ViewData["Title"] = "Votre panier";
    decimal total = Model.Lines.Any() ? Model.TotalAmount() + Order.DefaultServiceFee : 0m;
}

<div class="container py-5">

    <h2 class="fw-bold mb-4">Votre panier</h2>

    @if (!Model.Lines.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <p class="text-muted mt-3 fs-5">Votre panier est vide.</p>
            <a asp-controller="Product" asp-action="Index" class="btn btn-dark mt-2 px-4">
                <i class="bi bi-grid me-2"></i>Parcourir les produits
            </a>
        </div>
    }
    else
    {
        <div class="row g-4 align-items-start">

            <!-- Liste des articles -->
            <div class="col-lg-8" id="cart-lines">
                @foreach (var line in Model.Lines)
                {
                    <div class="card border rounded-3 mb-3 p-3 shadow-sm cart-item"
                         id="cart-item-@line.Product.ProductId" data-product-id="@line.Product.ProductId"
                         data-unit-price="@line.Product.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                        <div class="d-flex gap-3 align-items-center">

                            <!-- Image -->
                            <img src="@(line.Product.ImageUrl ?? "/images/placeholder.png")"
                                 class="rounded-3 flex-shrink-0"
                                 style="width:90px; height:90px; object-fit:cover;"
                                 alt="@line.Product.Name"
                                 onerror="this.src='/images/placeholder.png'" />

                            <!-- Infos produit -->
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <h6 class="fw-bold mb-0">@line.Product.Name</h6>
                                    </div>
                                    <button class="btn btn-link text-danger p-0 ms-3 btn-remove"
                                            data-product-id="@line.Product.ProductId" title="Supprimer">
                                        <i class="bi bi-trash3 fs-5"></i>
                                    </button>
                                </div>

                                <!-- Quantité + Prix -->
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <div class="d-flex align-items-center gap-2">
                                        <button class="btn btn-outline-secondary btn-sm rounded-circle btn-qty-minus"
                                                data-product-id="@line.Product.ProductId"
                                                style="width:32px; height:32px; padding:0;">
                                            <i class="bi bi-dash"></i>
                                        </button>
                                        <span class="fw-semibold qty-display" style="min-width:24px; text-align:center;">
                                            @line.Quantity
                                        </span>
                                        <button class="btn btn-outline-secondary btn-sm rounded-circle btn-qty-plus"
                                                data-product-id="@line.Product.ProductId"
                                                style="width:32px; height:32px; padding:0;">
                                            <i class="bi bi-plus"></i>
                                        </button>
                                    </div>
                                    <span class="fw-bold fs-6 line-subtotal">@line.SubTotal.ToString("0.00") €</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Résumé -->
            <div class="col-lg-4">
                <div class="card border rounded-3 shadow-sm p-4" id="cart-summary">
                    <h5 class="fw-bold mb-4">Résumé</h5>

                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Sous-total</span>
                        <span id="summary-subtotal">@Model.TotalAmount().ToString("0.00", System.Globalization.CultureInfo.InvariantCulture) €</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3">
                        <span class="text-muted">Frais de service</span>
                        <span>@Order.DefaultServiceFee.ToString("0.00") €</span>
                    </div>
                    <hr />
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <span class="fw-bold fs-6">Total</span>
                        <span class="fw-bold fs-4" id="summary-total">@total.ToString("0.00") €</span>
                    </div>

                    <div class="d-grid gap-2">
                        <a asp-controller="Order" asp-action="Checkout"
                           class="btn btn-success btn-lg fw-semibold">
                            <i class="bi bi-bag-check me-2"></i>Passer la commande
                        </a>
                        <a asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-secondary fw-semibold">
                            Continuer mes courses
                        </a>
                    </div>
                </div>
            </div>

        </div>
    }
</div>

@section Scripts {
    <script>
        const SERVICE_FEE = 5.95;

        function updateSummary(subTotal, total) {
            document.getElementById('summary-subtotal').textContent = subTotal.replace('.', ',') + ' €';
            document.getElementById('summary-total').textContent    = total.replace('.', ',') + ' €';
        }

        function updateBadge(count) {
            var badge = document.getElementById('cart-badge');
            if (badge) badge.textContent = count;
        }

        // Boutons quantité
        document.querySelectorAll('.btn-qty-minus, .btn-qty-plus').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var productId = this.dataset.productId;
                var item      = document.getElementById('cart-item-' + productId);
                var display   = item.querySelector('.qty-display');
                var current   = parseInt(display.textContent.trim());
                var newQty    = this.classList.contains('btn-qty-minus') ? Math.max(1, current - 1) : current + 1;

                if (newQty === current) return;

                fetch('/Cart/UpdateQuantity', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'productId=' + productId + '&quantity=' + newQty
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.success) return;
                    display.textContent = newQty;
                    var unitPrice = parseFloat(item.dataset.unitPrice);
                    item.querySelector('.line-subtotal').textContent = (unitPrice * newQty).toFixed(2).replace('.', ',') + ' €';
                    updateSummary(data.subTotal, data.total);
                    updateBadge(data.cartCount);
                });
            });
        });

        // Boutons supprimer
        document.querySelectorAll('.btn-remove').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var productId = this.dataset.productId;

                fetch('/Cart/Remove', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: 'productId=' + productId
                })
                .then(function (r) { return r.json(); })
                .then(function (data) {
                    if (!data.success) return;
                    document.getElementById('cart-item-' + productId).remove();
                    updateBadge(data.cartCount);
                    if (data.isEmpty) {
                        location.reload();
                    } else {
                        updateSummary(data.subTotal, data.total);
                    }
                });
            });
        });
    </script>
}
