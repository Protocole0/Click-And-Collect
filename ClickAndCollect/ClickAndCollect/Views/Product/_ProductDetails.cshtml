@model ClickAndCollect.Models.Product

<div class="row g-4">
    <div class="col-md-5">
        <img src="@Model.ImageUrl"
             class="img-fluid rounded-3 w-100"
             alt="@Model.Name"
             style="height:300px; object-fit:cover;"
             onerror="this.src='/images/placeholder.png'" />
    </div>
    <div class="col-md-7 d-flex flex-column">
        <h4 class="fw-bold mb-1">@Model.Name</h4>
        <p class="text-muted small mb-3">
            <i class="bi bi-tag me-1"></i>Catégorie #@Model.CategoryId
        </p>

        <p class="fs-2 fw-bold text-success mb-3">@Model.Price.ToString("0.00") €</p>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <div class="mb-3">
                <h6 class="fw-bold">Description</h6>
                <p class="text-muted small mb-0">@Model.Description</p>
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.NutritionalInfo))
        {
            <div class="mb-3">
                <h6 class="fw-bold">Informations nutritionnelles <span class="text-muted fw-normal small">(pour 100g)</span></h6>
                <div class="bg-light rounded-3 p-3">
                    @{
                        var parts = Model.NutritionalInfo.Split(',', System.StringSplitOptions.TrimEntries);
                    }
                    @foreach (var part in parts)
                    {
                        var kv = part.Split(':', 2);
                        <div class="d-flex justify-content-between border-bottom py-1 small">
                            @if (kv.Length == 2)
                            {
                                <span class="text-muted">@kv[0]</span>
                                <span class="fw-semibold text-success">@kv[1]</span>
                            }
                            else
                            {
                                <span class="text-muted">@part</span>
                            }
                        </div>
                    }
                </div>
            </div>
        }

        <div class="mt-auto">
            <h6 class="fw-bold mb-2">Quantité</h6>
            <div class="d-flex align-items-center gap-3">
                <div class="input-group" style="width:130px;">
                    <button class="btn btn-outline-secondary" type="button" id="btn-minus">
                        <i class="bi bi-dash"></i>
                    </button>
                    <input type="number" id="quantity" class="form-control text-center fw-bold"
                           value="1" min="1" />
                    <button class="btn btn-outline-secondary" type="button" id="btn-plus">
                        <i class="bi bi-plus"></i>
                    </button>
                </div>
                <button class="btn btn-dark flex-grow-1 py-2"
                        id="btn-add-cart"
                        data-product-id="@Model.ProductId"
                        data-unit-price="@Model.Price.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture)">
                    <i class="bi bi-cart3 me-2"></i>Ajouter au panier — @Model.Price.ToString("0.00") €
                </button>
            </div>
        </div>
    </div>
</div>
