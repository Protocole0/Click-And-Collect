@model ClickAndCollect.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Product" asp-action="Index">Catégories</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-controller="Product" asp-action="Browse" asp-route-id="@Model.CategoryId">Produits</a>
        </li>
        <li class="breadcrumb-item active">@Model.Name</li>
    </ol>
</nav>

<div class="row g-4">
    <div class="col-md-4">
        <img src="@Model.ImageUrl"
             class="img-fluid rounded shadow-sm"
             alt="@Model.Name"
             style="width:100%; height:300px; object-fit:cover;"
             onerror="this.src='/images/placeholder.png'" />
    </div>
    <div class="col-md-8">
        <h2>@Model.Name</h2>

        @if (!string.IsNullOrEmpty(Model.Description))
        {
            <p class="text-muted">@Model.Description</p>
        }

        @if (!string.IsNullOrEmpty(Model.NutritionalInfo))
        {
            <p><strong>Infos nutritives :</strong> @Model.NutritionalInfo</p>
        }

        <p class="fs-3 fw-bold text-success">@Model.Price.ToString("0.00") €</p>

        <button class="btn btn-primary">Ajouter au panier</button>
    </div>
</div>
