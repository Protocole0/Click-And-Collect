@using ClickAndCollect.ViewModels;
@model Order
@{
    var groupedLines = Model.Lines.GroupBy(x => x.Product.Category.Name);
    var totalLines = Model.Lines.Count();
    var totalItems = Model.TotalItems();
    var clientName = $"- {Model.Client.Firstname} {Model.Client.Lastname}";
}

<form id="prep-form" asp-action="ValidatePreparation" asp-route-orderId="@Model.Id" method="post">
    <div class="modal-body px-5 pb-4 pt-4">

        <div id="step-1-body" class="fade-in">
            <h5 class="fw-bold text-dark mb-4 text-center mt-2">
                <i class="bi bi-basket2 text-success me-2"></i>Contenu de la commande
            </h5>
            @foreach (var category in groupedLines)
            {
                <div class="mb-4">
                    <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing: 1px; font-size: 0.85rem;">@category.Key</h6>
                    <div class="d-flex flex-column gap-3">
                        @foreach (var orderLine in category)
                        {
                            <div class="card border-0 shadow-sm rounded-4">
                                <div class="card-body p-3 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center">
                                        <img src="@orderLine.Product.ImageUrl" loading="lazy" class="rounded-3 me-3 bg-light" style="width: 60px; height: 60px; object-fit: cover;">
                                        <h6 class="mb-1 fw-bold text-dark">@orderLine.Product.Name</h6>
                                    </div>
                                    <span class="fw-bold text-success fs-5 ms-3 text-end">x @orderLine.Quantity</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>

        <div id="step-2-body" class="d-none fade-in">
            <div class="d-flex justify-content-between align-items-center mb-3 bg-light p-3 rounded-4 shadow-sm">
                <h6 class="text-uppercase text-muted fw-bold mb-0" style="font-size: 0.8rem; letter-spacing: 1px;">
                    <i class="bi bi-list-check me-2 fs-5 align-middle text-success"></i> Progression
                </h6>
                <span class="badge bg-white text-dark border shadow-sm px-3 py-2 fs-6 rounded-pill" id="prep-counter">0 / @totalLines</span>
            </div>

            <div class="progress mb-4 shadow-sm" style="height: 20px; border-radius: 50px;">
                <div id="prep-progress-bar" class="progress-bar bg-success progress-bar-striped progress-bar-animated fw-bold" style="width: 0%;"></div>
            </div>

            @foreach (var category in groupedLines)
            {
                <div class="mb-4 pt-2">
                    <div class="d-flex align-items-center mb-3">
                        <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3 py-2 fw-bold text-uppercase">@category.Key</span>
                        <hr class="flex-grow-1 ms-3 text-muted opacity-25">
                    </div>
                    <div class="d-flex flex-column gap-2">
                        @foreach (var orderLine in category)
                        {
                            <label class="d-flex justify-content-between align-items-center bg-white border border-light shadow-sm rounded-4 p-2 prep-item" style="cursor: pointer; transition: all 0.3s;">
                                <div class="d-flex align-items-center px-3">
                                    <input class="form-check-input prep-checkbox m-0 shadow-none border-secondary" type="checkbox" name="checkedProducts" value="@orderLine.Id" style="width: 1.5rem; height: 1.5rem;">
                                </div>
                                <div class="bg-light rounded-3 p-1 me-3">
                                    <img src="@orderLine.Product.ImageUrl" loading="lazy" class="rounded-3" style="width: 50px; height: 50px; object-fit: cover;">
                                </div>
                                <div class="flex-grow-1">
                                    <h6 class="mb-0 fw-bold text-dark">@orderLine.Product.Name</h6>
                                </div>
                                <div class="ms-3 text-end pe-3">
                                    <span class="fs-5 fw-bold text-secondary">x @orderLine.Quantity</span>
                                </div>
                            </label>
                        }
                    </div>
                </div>
            }

            <div class="card border-0 bg-info bg-opacity-10 mt-5 mb-0 rounded-4 shadow-sm">
                <div class="card-body p-4 d-flex align-items-center">
                    <div class="bg-white text-info rounded-circle d-flex align-items-center justify-content-center shadow-sm me-4" style="width: 55px; height: 55px;">
                        <i class="bi bi-box2-fill fs-3"></i>
                    </div>
                    <div class="flex-grow-1">
                        <label for="crates-count" class="fw-bold text-dark mb-1 d-block fs-5">Caisses utilisées</label>
                        <p class="text-muted small mb-0">Combien de contenants pour cette commande ?</p>
                    </div>
                    <div style="width: 120px;">
                        <input type="number" name="cratesUsed" id="crates-count" class="form-control form-control-lg text-center border-info border-opacity-50 shadow-sm rounded-3 fw-bold text-info" placeholder="0" min="1" required>
                    </div>
                </div>
            </div>
        </div>

        <div id="step-3-body" class="d-none fade-in pt-3">
            <div class="text-center mb-4">
                <p class="text-muted px-3">Voulez-vous vraiment terminer la préparation de cette commande ?</p>
            </div>
            <div class="card border-0 bg-light rounded-4 shadow-sm mb-2 text-start">
                <div class="card-body p-4">
                    <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-10">
                        <small class="text-muted d-block mb-1">Commande</small>
                        <span class="fw-bold text-dark fs-6">#@Model.Id @clientName</span>
                    </div>
                    <div class="mb-4 pb-4 border-bottom border-secondary border-opacity-10">
                        <small class="text-muted d-block mb-1">Articles collectés</small>
                        <span class="fw-bold text-dark fs-6">@totalItems</span>
                    </div>
                    <div>
                        <small class="text-muted d-block mb-1">Caisses utilisées</small>
                        <span class="fw-bold text-dark fs-6" id="bill-crates-count">0</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-footer border-0 px-5 pb-5 pt-0 d-flex flex-column gap-2 bg-white">
        <div id="step-1-footer" class="w-100 fade-in">
            <button type="button" id="btn-go-to-prep" class="btn btn-success w-100 py-3 fw-bold rounded-4 shadow-sm fs-5">Commencer la préparation</button>
        </div>
        <div id="step-2-footer" class="w-100 d-none fade-in">
            <button type="button" id="btn-show-confirm" class="btn btn-success w-100 py-3 fw-bold rounded-4 shadow-sm fs-5" disabled>
                <i class="bi bi-check-circle-fill me-2 fs-4"></i> Valider la commande
            </button>
        </div>
        <div id="step-3-footer" class="w-100 d-none fade-in d-flex flex-column gap-3">
            <button type="submit" class="btn btn-success w-100 py-3 fw-bold rounded-4 shadow-sm fs-5">Confirmer définitivement</button>
            <button type="button" id="btn-back-to-prep" class="btn btn-light border w-100 py-3 fw-bold rounded-4 text-dark shadow-sm">Annuler</button>
        </div>
    </div>
</form>