@using System.Linq
@using ClickAndCollect.ViewModels
@model IEnumerable<OrderViewModel>

<div class="container py-5">
    <div class="text-center mb-5">
        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-3" style="width: 70px; height: 70px;">
            <i class="bi bi-box-seam fs-1"></i>
        </div>
        <h1 class="fw-bold text-dark tracking-tight mb-3">Préparation des commandes</h1>
        <p class="text-muted fs-5">Aperçu des retraits prévus pour demain</p>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-4 mb-5 d-flex align-items-center p-4 fade-in" role="alert">
            <i class="bi bi-check-circle-fill text-success fs-2 me-3"></i>
            <div>
                <h5 class="fw-bold mb-1 text-success">C'est tout bon !</h5>
                <p class="mb-0 fs-6 text-dark">@TempData["SuccessMessage"]</p>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-4">
            @foreach (var orderToPrep in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="#" data-orderid="@orderToPrep.OrderId" data-orderdate="@orderToPrep.OrderDate.ToString("dd/MM/yyyy")" data-ordertime="@orderToPrep.BookStart.ToString(@"hh\:mm") - @orderToPrep.BookEnd.ToString(@"hh\:mm")" data-clientname="@orderToPrep.ClientFirstname @orderToPrep.ClientLastname" data-clientphonenumber="@orderToPrep.ClientPhoneNumber" class="text-decoration-none order-preview-trigger">

                        <div class="card h-100 border-0 card-hover bg-white text-body shadow-sm rounded-4 overflow-hidden d-flex flex-column">
                            <div class="bg-primary opacity-25" style="height: 5px;"></div>

                            <div class="card-header bg-white border-bottom-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-bold text-uppercase" style="letter-spacing: 1px;">Commande #@orderToPrep.OrderId</span>
                                <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-3 py-2 fw-semibold border border-success border-opacity-25">
                                    @orderToPrep.OrderStatus
                                </span>
                            </div>

                            <div class="card-body p-4 d-flex flex-column flex-grow-1">

                                <h4 class="card-title fw-bold text-dark mb-4 pb-2 border-bottom">
                                    @orderToPrep.ClientFirstname @orderToPrep.ClientLastname
                                </h4>

                                <div class="d-flex flex-column gap-4 mb-5">

                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                            <i class="bi bi-clock-history text-primary fs-5"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold mb-1" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Retrait prévu</small>
                                            <span class="fw-bold text-dark fs-5">@orderToPrep.BookStart.ToString(@"hh\:mm") <span class="text-muted fw-normal mx-1">à</span> @orderToPrep.BookEnd.ToString(@"hh\:mm")</span>
                                        </div>
                                    </div>

                                    <div class="d-flex align-items-center">
                                        <div class="bg-info bg-opacity-10 rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 45px; height: 45px;">
                                            <i class="bi bi-basket2 text-info fs-5"></i>
                                        </div>
                                        <div>
                                            <small class="text-muted d-block fw-semibold mb-1" style="font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.5px;">Contenu</small>
                                            <span class="fw-medium text-dark">
                                                @orderToPrep.TotalItems @(orderToPrep.TotalItems > 1 ? "produits à préparer" : "produit à préparer")
                                            </span>
                                        </div>
                                    </div>

                                </div>

                                <div class="mt-auto bg-light rounded-3 p-3 d-flex align-items-center justify-content-between">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-telephone-fill text-success fs-5 me-3"></i>
                                        <div>
                                            <small class="text-muted d-block fw-semibold" style="font-size: 0.7rem; text-transform: uppercase;">Contact</small>
                                            <span class="fw-bold text-dark">@orderToPrep.ClientPhoneNumber</span>
                                        </div>
                                    </div>
                                    <div class="bg-white rounded-circle shadow-sm d-flex align-items-center justify-content-center" style="width: 30px; height: 30px;">
                                        <i class="bi bi-chevron-right text-primary small"></i>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="col-12">
            <div class="card border-0 shadow-sm p-5 text-center bg-white rounded-4">
                <div class="card-body py-5">
                    <div class="d-inline-flex align-items-center justify-content-center bg-light text-muted rounded-circle mb-4" style="width: 80px; height: 80px;">
                        <i class="bi bi-inbox fs-1"></i>
                    </div>
                    <h3 class="fw-bold mb-2 text-dark">Aucune commande en attente</h3>
                    <p class="text-muted mb-0 fs-5">C'est très calme par ici... Vous êtes à jour !</p>
                </div>
            </div>
        </div>
    }
</div>

<div class="moDAL fade" id="orderMoDAL" tabindex="-1" aria-labelledby="orderMoDALLabel" aria-hidden="true">
    <div class="moDAL-dialog moDAL-lg moDAL-dialog-centered">
        <div class="moDAL-content border-0 shadow-lg rounded-4">

            <div class="moDAL-header border-0 px-5 pt-5 pb-0 align-items-start">
                <div id="orderMoDALLabel" class="w-100"></div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="moDAL" aria-label="Fermer"></button>
            </div>

            <div class="moDAL-body px-5 pb-5 pt-4" id="orderMoDALBody">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Voir l'aperçu d'une commande
        document.querySelectorAll('.order-preview-trigger').forEach(function (el) {
            el.addEventListener('click', function (e) {
                e.preventDefault();

                var orderid = this.dataset.orderid;
                var orderdate = this.dataset.orderdate;
                var ordertime = this.dataset.ordertime;
                var clientname = this.dataset.clientname;
                var clientphonenumber = this.dataset.clientphonenumber;

                var moDAL = new bootstrap.MoDAL(document.getElementById('orderMoDAL'));
                var body = document.getElementById('orderMoDALBody');

                document.getElementById('orderMoDALLabel').innerHTML =
                '<h3 class="fw-bold text-dark mb-3">' + clientname + '</h3>' +
                '<div class="d-flex flex-wrap align-items-center gap-3 text-muted" style="font-size: 0.95rem;">' +
                    '<span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill border border-primary border-opacity-25"><i class="bi bi-clock me-1"></i> Retrait : ' + ordertime + '</span>' +
                    '<span><i class="bi bi-bag-check me-1"></i> Passée le ' + orderdate + '</span>' +
                    '<span><i class="bi bi-telephone me-1"></i> ' + clientphonenumber + '</span>' +
                '</div>';

                body.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary" role="status"></div><p class="text-muted mt-3 small">Chargement de la commande...</p></div>';
                moDAL.show();

                fetch('/Employee/OrderContent?orderId=' + orderid, {
                    headers: { 'X-Requested-With': 'XMLHttpRequest' }
                })
                .then(function (r) { return r.text(); })
                .then(function (html) { body.innerHTML = html; })
                .catch(function () {
                    body.innerHTML = '<div class="text-center py-5"><i class="bi bi-exclamation-triangle text-danger fs-1 mb-3 d-block"></i><p class="text-danger">Erreur lors du chargement.</p></div>';
                });
            });
        });

        // Passer à la préparation de la commande
        document.getElementById('orderMoDALBody').addEventListener('click', function(e) {
            if (e.target.id === 'btn-go-to-prep') {
                e.preventDefault();

                document.getElementById('orderMoDALLabel').innerHTML = '<h3 class="fw-bold text-success mb-0"><i class="bi bi-box-seam me-2"></i>Préparation en cours</h3>';

                document.getElementById('step-1-preview').classList.add('d-none');
                document.getElementById('step-2-prep').classList.remove('d-none');
            }
        });

        // Activer le bouton de la validation
        // de la préparation de la commande 
        // si les conditions sont remplies
        function checkValidationState() {
            var allCheckboxes = document.querySelectorAll('.prep-checkbox');
            var checkedCheckboxes = document.querySelectorAll('.prep-checkbox:checked');

            var total = allCheckboxes.length;
            var checked = checkedCheckboxes.length;
            var percent = total > 0 ? Math.round((checked / total) * 100) : 0;

            var cratesInput = document.getElementById('crates-count');
            var cratesValid = cratesInput && cratesInput.value > 0 && cratesInput.value !== "";

            var validateBtn = document.getElementById('btn-show-confirm');
            if (validateBtn) {
                validateBtn.disabled = !(percent === 100 && cratesValid);
            }
            return percent;
        }

        // Gérer les changements d'état des produits préparés et la saisie du nombre de caisses
        document.getElementById('orderMoDALBody').addEventListener('change', function(e) {
            if (e.target.classList.contains('prep-checkbox')) {
                var listItem = e.target.closest('.prep-item');
                var productName = listItem.querySelector('.prep-product-name');

                if (e.target.checked) {
                    listItem.classList.add('opacity-50', 'bg-light');
                    productName.classList.add('text-decoration-line-through');
                } else {
                    listItem.classList.remove('opacity-50', 'bg-light');
                    productName.classList.remove('text-decoration-line-through');
                }

                var percent = checkValidationState();

                var progressBar = document.getElementById('prep-progress-bar');
                var counter = document.getElementById('prep-counter');

                if (progressBar) {
                    progressBar.style.width = percent + '%';
                    progressBar.setAttribute('aria-valuenow', percent);
                    progressBar.innerText = percent + '%';
                    if (percent === 100) {
                        progressBar.classList.remove('progress-bar-striped', 'progress-bar-animated');
                    } else {
                        progressBar.classList.add('progress-bar-striped', 'progress-bar-animated');
                    }
                }
                if (counter) {
                    var total = document.querySelectorAll('.prep-checkbox').length;
                    var checked = document.querySelectorAll('.prep-checkbox:checked').length;
                    counter.innerText = checked + " / " + total;
                }
            }
        });

        document.getElementById('orderMoDALBody').addEventListener('input', function(e) {
            if (e.target.classList.contains('quantity-input')) {
                if (e.target.value <= 0 && e.target.value !== "") {
                    e.target.value = "";
                }
                checkValidationState();
            }
        });

        // Voir le message de confirmation 
        // avant de valider la commande préparée
        // ou revenir à la checklist de préparation
        document.getElementById('orderMoDALBody').addEventListener('click', function(e) {

            var showConfirmBtn = e.target.closest('#btn-show-confirm');
            if (showConfirmBtn && !showConfirmBtn.disabled) {
                e.preventDefault();

                var cratesInput = document.getElementById('crates-count').value;
                var summaryCrates = document.getElementById('summary-crates-count');
                if(summaryCrates) {
                    summaryCrates.innerText = cratesInput;
                }

                document.getElementById('step-2-prep').classList.add('d-none');
                document.getElementById('step-3-confirm').classList.remove('d-none');

                document.getElementById('orderMoDALLabel').parentElement.classList.add('d-none');
            }

            if (e.target.id === 'btn-back-to-prep') {
                e.preventDefault();

                document.getElementById('step-3-confirm').classList.add('d-none');
                document.getElementById('step-2-prep').classList.remove('d-none');

                document.getElementById('orderMoDALLabel').parentElement.classList.remove('d-none');
            }
        });
    </script>
}