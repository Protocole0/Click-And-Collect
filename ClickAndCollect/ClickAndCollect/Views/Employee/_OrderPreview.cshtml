@model ClickAndCollect.Models.Order

<div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
    <div>
        <span class="text-muted small d-block">Numéro de commande</span>
        <strong class="fs-5" style="color: #0f3460;">#@Model.Id</strong>
    </div>
    <div class="text-end">
        <span class="text-muted small d-block">Date de passage</span>
        <strong class="fs-6 text-body">@Model.OrderDate.ToString("dd/MM/yyyy à HH:mm")</strong>
    </div>
</div>

<h6 class="text-muted text-uppercase mb-3 fw-bold" style="letter-spacing: 0.5px;">Produits à préparer</h6>

<div class="list-group list-group-flush mb-4">
    @foreach (var orderLine in Model.OrderLines)
    {
        <div class="list-group-item px-0 py-3 d-flex justify-content-between align-items-center">

            <div class="d-flex align-items-center">
                <img src="@orderLine.Product.ImageUrl" alt="@orderLine.Product.Name" class="rounded me-3" style="width: 50px; height: 50px; object-fit: cover;"> 

                <div>
                    <h6 class="mb-0 fw-bold">@orderLine.Product.Name</h6>
                </div>
            </div>

            <div class="ms-3">
                <span class="badge rounded-pill fs-6" style="background-color: #f8f9fa; color: #212529; border: 1px solid #dee2e6;">
                    x @orderLine.Quantity
                </span>
            </div>

        </div>
    }
</div>

<div class="bg-light rounded p-3 text-center">
    <p class="mb-2 text-muted">Avez-vous réuni tous les articles de cette liste ?</p>
    <button class="btn btn-success px-4 py-2 fw-bold">Valider la préparation</button>
</div>