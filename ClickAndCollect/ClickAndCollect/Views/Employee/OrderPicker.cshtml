@using ClickAndCollect.ViewModels
@using System.Globalization
@model IEnumerable<OrderDisplayViewModel>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 text-primary rounded-3 d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="bi bi-box-seam fs-3"></i>
            </div>
            <div>
                <h2 class="fw-bold text-dark mb-0">Préparation des commandes</h2>
                <p class="text-muted mb-0 small">Aperçu des retraits prévus</p>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="mt-3 mt-md-0 text-md-end">
                <span class="badge bg-light text-dark border border-secondary border-opacity-25 px-3 py-2 fs-6 shadow-sm fw-medium text-capitalize">
                    <i class="bi bi-calendar3 text-primary me-2"></i>
                    @Model.First().TimeSlotDate.ToString("dddd d MMMM yyyy", new CultureInfo("fr-FR"))
                </span>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center p-3 fade-in" role="alert">
            <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
            <div>
                <h6 class="fw-bold mb-0 text-success">C'est tout bon !</h6>
                <p class="mb-0 small text-dark">@TempData["SuccessMessage"]</p>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var orderToPrep in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="#"
                       data-orderid="@orderToPrep.OrderId"
                       data-clientname="@orderToPrep.GetClientFullName()"
                       data-clientphone="@orderToPrep.ClientPhoneNumber"
                       class="text-decoration-none order-preview-trigger">

                        <div class="card h-100 border-0 card-hover bg-white text-body shadow-sm rounded-4 overflow-hidden d-flex flex-column border-top border-primary border-4">
                            <div class="card-header bg-white border-bottom-0 px-4 pt-3 pb-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-bold text-uppercase">CMD #@orderToPrep.OrderId</span>
                                <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 py-1 small">À préparer</span>
                            </div>

                            <div class="card-body p-4 d-flex flex-column flex-grow-1">
                                <h5 class="card-title fw-bold text-dark mb-3 pb-2 border-bottom">@orderToPrep.GetClientFullName()</h5>
                                <div class="d-flex flex-column gap-2 mb-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-clock-history text-primary fs-5 me-2"></i>
                                        <div>
                                            <span class="text-muted small d-block" style="line-height: 1;">Créneau</span>
                                            <span class="fw-bold text-dark">@orderToPrep.GetTimeSlotLabel()</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center mt-1">
                                        <i class="bi bi-basket2 text-primary fs-5 me-2"></i>
                                        <div>
                                            <span class="text-muted small d-block" style="line-height: 1;">Contenu</span>
                                            <span class="fw-medium text-dark">@orderToPrep.GetTotalItems() @(orderToPrep.GetTotalItems() > 1 ? "articles" : "article")</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-4 text-center bg-white rounded-4 mt-2">
            <div class="card-body py-4">
                <i class="bi bi-inbox fs-1 text-muted mb-3 d-block"></i>
                <h5 class="fw-bold mb-1 text-dark">Aucune commande en attente</h5>
                <p class="text-muted mb-0 small">C'est très calme par ici... Vous êtes à jour !</p>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="orderPickerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 px-5 pt-5 pb-0 align-items-start">
                <div class="w-100" id="orderPickerModalHeader"></div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div id="orderPickerModalContent"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('click', function (e) {
            var trigger = e.target.closest('.order-preview-trigger');
            if (!trigger) return;
            e.preventDefault();

            var modal = new bootstrap.Modal(document.getElementById('orderPickerModal'));
            var header = document.getElementById('orderPickerModalHeader');
            var content = document.getElementById('orderPickerModalContent');

            header.innerHTML =
                '<h3 class="fw-bold text-dark mb-1" id="modal-dynamic-title">' + trigger.dataset.clientname + '</h3>' +
                '<p class="text-muted small mb-0">Commande #' + trigger.dataset.orderid + ' &bull; ' + trigger.dataset.clientphone + '</p>';

            content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-primary" role="status"></div></div>';
            modal.show();

            fetch('/Employee/OrderData?orderId=' + trigger.dataset.orderid)
                .then(r => r.text())
                .then(html => { content.innerHTML = html; })
                .catch(() => { content.innerHTML = '<div class="p-5 text-center text-danger">Erreur de chargement.</div>'; });
        });

        document.addEventListener('click', function(e) {
            var container = document.getElementById('orderPickerModalContent');
            if (!container || !container.contains(e.target)) return;
            var title = document.getElementById('modal-dynamic-title');

            if (e.target.closest('#btn-go-to-prep')) {
                e.preventDefault();
                if(title) title.innerHTML = '<span class="text-success"><i class="bi bi-box-seam me-2"></i>Préparation en cours</span>';
                toggleSteps(container, 'step-1', 'step-2');
            }
            if (e.target.closest('#btn-show-confirm') && !e.target.closest('#btn-show-confirm').disabled) {
                e.preventDefault();
                if(title) title.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-circle me-2"></i>Confirmation</span>';
                container.querySelector('#summary-crates-count').innerText = container.querySelector('#crates-count').value;
                toggleSteps(container, 'step-2', 'step-3');
            }
            if (e.target.closest('#btn-back-to-prep')) {
                e.preventDefault();
                if(title) title.innerHTML = '<span class="text-success"><i class="bi bi-box-seam me-2"></i>Préparation en cours</span>';
                toggleSteps(container, 'step-3', 'step-2');
            }
        });

        document.addEventListener('change', function(e) {
            var container = document.getElementById('orderPickerModalContent');
            if (container && e.target.classList.contains('prep-checkbox')) {
                var item = e.target.closest('.prep-item');
                item.classList.toggle('opacity-50', e.target.checked);
                item.classList.toggle('bg-light', e.target.checked);
                updateProgress(container);
            }
        });

        document.addEventListener('input', function(e) {
            var container = document.getElementById('orderPickerModalContent');
            if (container && e.target.id === 'crates-count') updateProgress(container);
        });

        function toggleSteps(container, hide, show) {
            container.querySelector('#' + hide + '-body').classList.add('d-none');
            container.querySelector('#' + hide + '-footer').classList.add('d-none');
            container.querySelector('#' + show + '-body').classList.remove('d-none');
            container.querySelector('#' + show + '-footer').classList.remove('d-none');
        }

        function updateProgress(container) {
            var all = container.querySelectorAll('.prep-checkbox').length;
            var checked = container.querySelectorAll('.prep-checkbox:checked').length;
            var percent = all > 0 ? Math.round((checked / all) * 100) : 0;

            var bar = container.querySelector('#prep-progress-bar');
            var counter = container.querySelector('#prep-counter');
            var btn = container.querySelector('#btn-show-confirm');
            var crates = container.querySelector('#crates-count');

            if (bar) bar.style.width = percent + '%';
            if (counter) counter.innerText = checked + " / " + all;
            if (btn && crates) btn.disabled = !(percent === 100 && crates.value > 0);
        }
    </script>
}