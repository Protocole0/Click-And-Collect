@using ClickAndCollect.ViewModels
@using System.Globalization
@model IEnumerable<OrderDisplayViewModel>

<div class="container py-4">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-end mb-4 border-bottom pb-3">
        <div class="d-flex align-items-center">
            <div class="bg-success bg-opacity-10 text-success rounded-3 d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 50px; height: 50px;">
                <i class="bi bi-cash-register fs-3"></i>
            </div>
            <div>
                <h2 class="fw-bold text-dark mb-0">Espace Caisse & Retrait</h2>
                <p class="text-muted mb-0 small">Commandes prêtes à être remises aux clients</p>
            </div>
        </div>
        @if (Model.Any())
        {
            <div class="mt-3 mt-md-0 text-md-end">
                <span class="badge bg-light text-dark border border-secondary border-opacity-25 px-3 py-2 fs-6 shadow-sm fw-medium text-capitalize">
                    <i class="bi bi-calendar-check text-success me-2"></i>
                    @Model.First().TimeSlotDate.ToString("dddd d MMMM yyyy", new CultureInfo("fr-FR"))
                </span>
            </div>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-4 d-flex align-items-center p-3 fade-in" role="alert">
            <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
            <div>
                <h6 class="fw-bold mb-0 text-success">Succès !</h6>
                <p class="mb-0 small text-dark">@TempData["SuccessMessage"]</p>
            </div>
            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var orderToPU in Model)
            {
                <div class="col-12 col-md-6 col-lg-4">
                    <a asp-action="#"
                       data-orderid="@orderToPU.OrderId"
                       data-clientname="@orderToPU.GetClientFullName()"
                       data-clientphone="@orderToPU.ClientPhoneNumber"
                       class="text-decoration-none cashier-preview-trigger">

                        <div class="card h-100 border-0 card-hover bg-white text-body shadow-sm rounded-4 overflow-hidden d-flex flex-column border-top border-success border-4">
                            <div class="card-header bg-white border-bottom-0 px-4 pt-3 pb-0 d-flex justify-content-between align-items-center">
                                <span class="text-muted small fw-bold text-uppercase">CMD #@orderToPU.OrderId</span>
                                <span class="badge bg-success text-white rounded-pill px-2 py-1 small shadow-sm">Prête</span>
                            </div>

                            <div class="card-body p-4 d-flex flex-column flex-grow-1">
                                <h5 class="card-title fw-bold text-dark mb-3 pb-2 border-bottom">@orderToPU.GetClientFullName()</h5>
                                <div class="d-flex flex-column gap-2 mb-3">
                                    <div class="d-flex align-items-center">
                                        <i class="bi bi-clock-history text-success fs-5 me-2"></i>
                                        <div>
                                            <span class="text-muted small d-block" style="line-height: 1;">Retrait prévu</span>
                                            <span class="fw-bold text-dark">@orderToPU.GetTimeSlotLabel()</span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-center mt-2 p-2 bg-success bg-opacity-10 rounded-3">
                                        <i class="bi bi-currency-euro fs-3 text-success me-2"></i>
                                        <div>
                                            <span class="text-success small d-block fw-bold" style="line-height: 1;">À encaisser</span>
                                            <span class="fw-black text-success fs-4" style="font-weight: 900;">
                                                @orderToPU.GetTTCTotalPrice().ToString("0.00") €
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm p-4 text-center bg-white rounded-4 mt-2">
            <div class="card-body py-4">
                <i class="bi bi-check2-circle fs-1 text-muted mb-3 d-block"></i>
                <h5 class="fw-bold mb-1 text-dark">Aucun retrait en attente</h5>
                <p class="text-muted mb-0 small">Toutes les commandes préparées ont été remises !</p>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="cashierModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 px-5 pt-5 pb-0 align-items-start">
                <div class="w-100" id="cashierModalHeader"></div>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Fermer"></button>
            </div>
            <div id="cashierModalContent" data-crate-price=@Order.DefaultServiceFee></div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    @* -- Show the order bill -- *@
    @* The JS is listenning the click on the link *@
    document.addEventListener('click', function (e) {
        @* Here, JS try to find this class, even if the item clicked is indoor the class *@
        var trigger = e.target.closest('.cashier-preview-trigger');
        @* If JS didn't find the class at the emplacement clicked, the JS get out the function *@
        if (!trigger)
            return;
        @* Prevents the default behaviour of the link *@
        e.preventDefault();

        var modal = new bootstrap.Modal(document.getElementById('cashierModal'));
        var header = document.getElementById('cashierModalHeader');
        var content = document.getElementById('cashierModalContent');

        @* Once the modal window get, the header of it must be changed *@
        header.innerHTML =
            '<h3 class="fw-bold text-dark mb-1" id="modal-dynamic-title-cashier">' + trigger.dataset.clientname + '</h3>' +
            '<p class="text-muted small mb-0">Commande #' + trigger.dataset.orderid + ' &bull; ' + trigger.dataset.clientphone + '</p>';

        @* A spinner is added while the modal window loads *@
        content.innerHTML = '<div class="modal-body text-center py-5"><div class="spinner-border text-success" role="status"></div></div>';
        @* This Bootstrap method is used to show the modal block *@
        modal.show();

        @* Here is the AJAX fetch method
           With this, the page doesn't have to reload, 
           because the modal is just pu to "Show"
           It redirect towards the OrderData action
           giving the orderId to find the order associated*@
        fetch('/Employee/OrderData?orderId=' + trigger.dataset.orderid)
            .then(r => r.text())
            .then(html => { content.innerHTML = html; })
            .catch(() => { content.innerHTML = '<div class="p-5 text-center text-danger">Erreur de chargement.</div>'; });
    });

    @* -- Manage the crates count input -- *@
    @* JS is listening an input *@
    document.addEventListener('input', function(e) {
        var container = document.getElementById('cashierModalContent');

        @* If the container exists at that moment
           and if the input id is "crates-returned" *@
        if (container && e.target.id === 'crates-returned') {
            var input = e.target;

            @* Convert the input (string) in an integer *@
            var val = parseInt(input.value);

            @* If the value of the input is wrong 
               like NaN or less than 0,
               the input becomes empty *@
            if (isNaN(val) || val < 0) {
                val = 0;
                input.value = "";
            }

            @* Disable the confirm button if the value is an empty string *@
            var btn = container.querySelector('#btn-show-confirm');
            if(btn)
                btn.disabled = input.value === "";

            @* Retrieve all the elements linked 
               to the dynamic total changes *@
            var deductionRow = container.querySelector('#deduction-row');
            var cratesCountLabel = container.querySelector('#returned-crates-count');
            var deductionEl = container.querySelector('#dynamic-deduction');
            var totalLabelEl = container.querySelector('#total-due-label');
            var totalBlockEl = container.querySelector('#total-due-block');
            var finalTotalEl = container.querySelector('#dynamic-final-total');

            if (finalTotalEl && deductionEl) {
                var cratePrice = parseFloat(container.dataset.cratePrice) || 5.95;
                var deduction = val * cratePrice;

                var baseTotal = parseFloat(finalTotalEl.dataset.basetotal.replace(',', '.'));
                var newTotal = baseTotal - deduction;

                if (cratesCountLabel) cratesCountLabel.innerText = val;
                deductionEl.innerText = "- " + deduction.toFixed(2).replace('.', ',') + " €";

                if (val > 0) {
                    deductionRow.classList.remove('d-none');
                } else {
                    deductionRow.classList.add('d-none');
                }

                if (newTotal < 0) {
                    var refundAmount = Math.abs(newTotal);
                    finalTotalEl.innerText = refundAmount.toFixed(2).replace('.', ',') + " €";

                    if (totalLabelEl) totalLabelEl.innerText = "Le magasin doit au client";

                    if (totalBlockEl) {
                        totalBlockEl.classList.remove('bg-success', 'bg-opacity-10', 'text-success');
                        totalBlockEl.classList.add('bg-danger', 'bg-opacity-10', 'text-danger');
                    }
                    if (finalTotalEl) {
                        finalTotalEl.classList.remove('text-success');
                        finalTotalEl.classList.add('text-danger');
                    }
                    if (totalLabelEl) {
                        totalLabelEl.classList.remove('text-success');
                        totalLabelEl.classList.add('text-danger');
                    }
                } else {
                    finalTotalEl.innerText = newTotal.toFixed(2).replace('.', ',') + " €";

                    if (totalLabelEl) totalLabelEl.innerText = "Total à régler";

                    if (totalBlockEl) {
                        totalBlockEl.classList.remove('bg-danger', 'bg-opacity-10', 'text-danger');
                        totalBlockEl.classList.add('bg-success', 'bg-opacity-10', 'text-success');
                    }
                    if (finalTotalEl) {
                        finalTotalEl.classList.remove('text-danger');
                        finalTotalEl.classList.add('text-success');
                    }
                    if (totalLabelEl) {
                        totalLabelEl.classList.remove('text-danger');
                        totalLabelEl.classList.add('text-success');
                    }
                }
            }
        }
    });

    @* -- Show the confirmation window -- *@
    document.addEventListener('click', function(e) {
        var container = document.getElementById('cashierModalContent');

        @* if the class "cashierModalContent" doesn't exist yet
           or if the class is not concerned by the click,
           JS get out of the method *@
        if (!container || !container.contains(e.target))
            return;

        var title = document.getElementById('modal-dynamic-title-cashier');

        @* If the emplacement clicked is well "#btn-show-confirm",
           then you change the title content and display
           the confirmation modal div *@
        if (e.target.closest('#btn-show-confirm')) {
            e.preventDefault();
            if(title) title.innerHTML = '<span class="text-warning"><i class="bi bi-exclamation-circle me-2"></i>Confirmation</span>';
            @* Set the crates returned input in the title modal div and if it's empty, then set 0 *@
            container.querySelector('#bill-crates-returned').innerText = container.querySelector('#crates-returned').value || 0;
            @* Use the function to hide step-1 but show step-2 *@
            toggleCashierSteps(container, 'step-1', 'step-2');
        }

        @* If the order picker choose to return to the bill,
           then you do the opposite by showing step-1 and hiding step-2 *@
        if (e.target.closest('#btn-back-to-bill')) {
            e.preventDefault();
            if(title) title.innerHTML = '<span class="text-success"><i class="bi bi-cash-register me-2"></i>Encaissement</span>';
            toggleCashierSteps(container, 'step-2', 'step-1');
        }
    });


    function toggleCashierSteps(container, hide, show) {
        container.querySelector('#' + hide + '-body').classList.add('d-none');
        container.querySelector('#' + hide + '-footer').classList.add('d-none');
        container.querySelector('#' + show + '-body').classList.remove('d-none');
        container.querySelector('#' + show + '-footer').classList.remove('d-none');
    }
</script>
}