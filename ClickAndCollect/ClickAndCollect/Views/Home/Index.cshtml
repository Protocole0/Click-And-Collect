@{
    ViewData["Title"] = "Accueil";
}

<!-- Hero -->
<section class="hero d-flex align-items-center">
    <div class="container text-center text-white py-5">
        <i class="bi bi-basket2-fill display-1 text-success mb-3 d-block"></i>
        <h1 class="display-4 fw-bold mb-3">Faites vos courses en ligne</h1>
        <p class="lead mb-4 text-white-50">
            Commandez depuis chez vous et récupérez vos articles directement en magasin,<br />
            au créneau qui vous convient.
        </p>
        <a asp-controller="Product" asp-action="Index" class="btn btn-success btn-lg px-5 shadow">
            <i class="bi bi-grid me-2"></i>Voir nos produits
        </a>
    </div>
</section>

<!-- Fonctionnalités -->
<section class="py-5 bg-light">
    <div class="container">
        <h2 class="text-center fw-bold mb-5">Comment ça marche ?</h2>
        <div class="row g-4 text-center">
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-3 bg-white shadow-sm h-100">
                    <div class="feature-icon bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="bi bi-laptop fs-2"></i>
                    </div>
                    <h5 class="fw-bold">1. Commandez en ligne</h5>
                    <p class="text-muted small mb-0">
                        Parcourez nos catégories, choisissez vos produits et composez votre panier en quelques clics.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-3 bg-white shadow-sm h-100">
                    <div class="feature-icon bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="bi bi-geo-alt fs-2"></i>
                    </div>
                    <h5 class="fw-bold">2. Choisissez votre magasin</h5>
                    <p class="text-muted small mb-0">
                        Sélectionnez le magasin le plus proche et réservez un créneau de retrait à votre convenance.
                    </p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card p-4 rounded-3 bg-white shadow-sm h-100">
                    <div class="feature-icon bg-success bg-opacity-10 text-success rounded-circle mx-auto mb-3">
                        <i class="bi bi-bag-check fs-2"></i>
                    </div>
                    <h5 class="fw-bold">3. Récupérez vos articles</h5>
                    <p class="text-muted small mb-0">
                        Venez en magasin au créneau choisi et repartez avec vos courses, sans attente.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Avantages -->
<section class="py-5">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-md-6">
                <h2 class="fw-bold mb-3">Pourquoi choisir Click & Collect ?</h2>
                <ul class="list-unstyled">
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success rounded-pill me-3 mt-1 p-2">
                            <i class="bi bi-check-lg"></i>
                        </span>
                        <div>
                            <strong>Gain de temps</strong>
                            <p class="text-muted small mb-0">Plus besoin de faire la queue en caisse. Vos courses sont prêtes à votre arrivée.</p>
                        </div>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success rounded-pill me-3 mt-1 p-2">
                            <i class="bi bi-check-lg"></i>
                        </span>
                        <div>
                            <strong>Produits frais</strong>
                            <p class="text-muted small mb-0">Nos produits sont préparés le jour même par notre équipe en magasin.</p>
                        </div>
                    </li>
                    <li class="d-flex align-items-start mb-3">
                        <span class="badge bg-success rounded-pill me-3 mt-1 p-2">
                            <i class="bi bi-check-lg"></i>
                        </span>
                        <div>
                            <strong>Créneaux flexibles</strong>
                            <p class="text-muted small mb-0">Choisissez l'heure de retrait qui correspond à votre emploi du temps.</p>
                        </div>
                    </li>
                </ul>
                <a asp-controller="Product" asp-action="Index" class="btn btn-outline-success mt-2">
                    <i class="bi bi-arrow-right me-1"></i>Commencer mes courses
                </a>
            </div>
            <div class="col-md-6 text-center">
                <div class="bg-success bg-opacity-10 rounded-4 p-5">
                    <i class="bi bi-shop display-1 text-success"></i>
                    <p class="text-muted mt-3 mb-0">Disponible dans nos magasins partenaires</p>
                </div>
            </div>
        </div>
    </div>
</section>
