<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Click & Collect</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="d-flex flex-column min-vh-100">

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold fs-4" asp-controller="Home" asp-action="Index">
                <i class="bi bi-basket2-fill text-success me-2"></i>Click & Collect
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-controls="navbarMain"
                    aria-expanded="false" aria-label="Navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                @{
                    bool isLoggedIn = Context.Session.GetInt32("user_id").HasValue;
                    string? userType = Context.Session.GetString("user_type");
                    string? fullname = isLoggedIn
                    ? $"{Context.Session.GetString("client_firstname")} {Context.Session.GetString("client_lastname")}"
                    : null;
                    bool isEmployee = userType == "cashier" || userType == "orderpicker";
                }
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    @if (!isEmployee)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i>Accueil
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Product" asp-action="Index">
                                <i class="bi bi-grid me-1"></i>Nos produits
                            </a>
                        </li>
                    }
                </ul>
                <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
                    @if (isLoggedIn)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                @if (isEmployee)
                                {
                                    <i class="bi bi-person-badge me-1"></i>
                                }
                                else
                                {
                                    <i class="bi bi-person-check me-1"></i>
                                }
                                @fullname
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                @if (isEmployee)
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Employee" asp-action="Dashboard">
                                            <i class="bi bi-grid me-1"></i>Tableau de bord
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                else
                                {
                                    <li>
                                        <a class="dropdown-item" asp-controller="Order" asp-action="History">
                                            <i class="bi bi-clock-history me-1"></i>Mes commandes
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                }
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right me-1"></i>Se déconnecter
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Login">
                                <i class="bi bi-person me-1"></i>Connexion
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account" asp-action="Register">
                                <i class="bi bi-person-plus me-1"></i>Créer un compte
                            </a>
                        </li>
                    }
                    @if (!isEmployee)
                    {
                        <li class="nav-item">
                            <a class="nav-link position-relative" asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-cart3 fs-5"></i>
                                @{
                                    var cartCount = ClickAndCollect.Models.Order.GetFromSession(Context.Session).TotalItems();
                                }
                                <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-success">
                                    @cartCount
                                </span>
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <footer class="bg-dark text-white mt-5 pt-4 pb-3">
        <div class="container">
            <div class="row gy-3">
                <div class="col-md-4">
                    <h6 class="fw-bold mb-2">
                        <i class="bi bi-basket2-fill text-success me-2"></i>Click & Collect
                    </h6>
                    <p class="text-muted small mb-0">
                        Commandez en ligne et récupérez vos courses directement en magasin.
                    </p>
                </div>
                @if (!isEmployee)
                {
                    <div class="col-md-4">
                        <h6 class="fw-bold mb-2">Navigation</h6>
                        <ul class="list-unstyled small">
                            <li><a class="text-muted text-decoration-none" asp-controller="Home" asp-action="Index">Accueil</a></li>
                            <li><a class="text-muted text-decoration-none" asp-controller="Product" asp-action="Index">Nos produits</a></li>
                        </ul>
                    </div>
                }
                <div class="col-md-4">
                    <h6 class="fw-bold mb-2">Contact</h6>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-envelope me-1"></i>contact@clickcollect.be<br />
                        <i class="bi bi-geo-alt me-1"></i>Charleroi, Belgique
                    </p>
                </div>
            </div>
            <hr class="border-secondary mt-3 mb-2" />
            <p class="text-muted small text-center mb-0">
                &copy; 2026 Click & Collect — Haute École Condorcet
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.0/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>